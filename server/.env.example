# ──────────────────────────────────────────────────────────────────────────
# LinkSpan signaling server — environment template
# Copy to `.env` for local dev, or set these in the Render dashboard for prod.
# Values marked [REQUIRED IN PROD] are enforced at boot when NODE_ENV=production
# (the server refuses to start without them — see src/http/prodPrereqs.js).
# ──────────────────────────────────────────────────────────────────────────

# Set to "production" on Render. This turns on the production prerequisite gate.
NODE_ENV=production

# Port. Render injects this automatically — leave unset on Render. Local default: 10000.
# PORT=10000

# ── Secrets [REQUIRED IN PROD] ────────────────────────────────────────────
# Generate each with:  openssl rand -hex 32
TOKEN_SECRET=                 # HMAC secret for signaling/share tokens. MUST be stable across restarts.
AUTH_JWT_SECRET=              # JWT secret for accounts/API keys. Falls back to TOKEN_SECRET if unset.
METRICS_TOKEN=               # Bearer token gating /stats and /metrics. Required in prod.

# ── CORS [REQUIRED IN PROD] ───────────────────────────────────────────────
# Your deployed client origin. Never "*" in production. No trailing slash.
CORS_ORIGIN=https://your-app.vercel.app

# ── Proxy [REQUIRED IN PROD] ──────────────────────────────────────────────
# Number of trusted proxy hops in front of the server. Render terminates TLS at
# one proxy, so use 1. Needed so per-IP rate limiting reads the real client IP.
TRUSTED_PROXY_COUNT=1

# Public URLs (used to build share links and OAuth redirects). No trailing slash.
PUBLIC_BASE_URL=https://your-signaling.onrender.com
SHARE_VIEW_URL=https://your-app.vercel.app

# ── Redis — Upstash Free ──────────────────────────────────────────────────
# Optional but recommended: enables persistent rate-limiting, brute-force lockouts,
# and share-link metadata across restarts. Use the `rediss://` (TLS) URL from Upstash.
# Omit entirely to fall back to in-memory (fine for a single instance).
REDIS_URL=rediss://default:YOUR_UPSTASH_PASSWORD@YOUR-ENDPOINT.upstash.io:6379

# ── Share-link blob storage [REQUIRED IN PROD] ────────────────────────────
# Production refuses the filesystem/memory backends. Any S3-compatible store works
# via S3_ENDPOINT (forcePathStyle + relaxed checksums auto-enable when it is set).
#
# Recommended free tier: Backblaze B2 — 10 GB free, no card, fits the full 5 GB
# per-link cap (Supabase free is only 1 GB total). Setup:
#   1. backblaze.com → create account → Buckets → Create Bucket (private).
#   2. Note the bucket's Endpoint (e.g. s3.us-west-004.backblazeb2.com);
#      the region is the endpoint segment after "s3." (e.g. us-west-004).
#   3. App Keys → Add a New Application Key, scoped to that bucket
#      (keyID → S3_ACCESS_KEY_ID, applicationKey → S3_SECRET_ACCESS_KEY).
#   4. Verify from server/:  node scripts/verify-s3-backend.mjs --mb 64
SHARE_STORAGE=s3
S3_BUCKET=linkspan-blobs
S3_REGION=us-west-004
S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com
S3_ACCESS_KEY_ID=YOUR_B2_KEY_ID
S3_SECRET_ACCESS_KEY=YOUR_B2_APPLICATION_KEY
S3_PREFIX=blobs/
# Multipart upload tuning (optional): part size in MiB (min 5) and parallel
# in-flight parts per upload. Raise concurrency on high-latency routes.
# S3_UPLOAD_PART_SIZE_MB=8
# S3_UPLOAD_CONCURRENCY=8
#
# Supabase Storage also works (1 GB free):
# S3_REGION=us-east-1
# S3_ENDPOINT=https://YOUR-PROJECT-REF.supabase.co/storage/v1/s3

# ── Database — Supabase Free (OPTIONAL) ───────────────────────────────────
# Only needed to PERSIST user accounts / API keys across restarts. The app works
# fully without it (anonymous use + in-memory accounts). Enabling it requires
# adding Prisma — see DEPLOYMENT.md "Optional: persistent accounts". Use the
# Supabase pooler connection string (port 6543) for serverless-friendly pooling.
# DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true

# ── Rate-limit tuning (optional — sensible defaults exist) ─────────────────
# RL_MAX_CONNECTIONS_PER_MIN=60
# RL_MAX_JOIN_ATTEMPTS_PER_MIN=30
# RL_MAX_MESSAGES_PER_SEC=50
# RL_MAX_SESSIONS_PER_HOUR=100

# ── Misc (optional) ───────────────────────────────────────────────────────
# AUDIT_LOG_STDOUT=true        # emit audit log to stdout (handy on Render logs)
# METRICS_PUBLIC=false         # keep /metrics private
# API_ALLOW_ANONYMOUS=true     # allow anonymous share-link creation
# WEBHOOK_ALLOW_PRIVATE=false  # block webhooks to private IPs (SSRF guard) — keep false
