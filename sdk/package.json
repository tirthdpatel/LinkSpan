{
  "name": "@linkspan/sdk",
  "version": "0.1.0",
  "description": "Official JavaScript/TypeScript/Node SDK for the LinkSpan share-link REST API",
  "type": "module",
  "main": "src/index.js",
  "module": "src/index.js",
  "types": "index.d.ts",
