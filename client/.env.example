# ──────────────────────────────────────────────────────────────────────────
# LinkSpan client (Vite) — environment template
# These are read at BUILD time (import.meta.env.*), so changing any value
# requires a redeploy on Vercel. Set them in Vercel → Project → Settings →
# Environment Variables. Copy to `.env.local` for local dev.
# ──────────────────────────────────────────────────────────────────────────

# WebSocket URL of the signaling server (Render). MUST be wss:// in production
# (Vercel serves over https, so ws:// would be blocked as mixed content).
VITE_SIGNALING_URL=wss://your-signaling.onrender.com

# REST API base for share links / telemetry. Optional — if unset it is derived
# from VITE_SIGNALING_URL (wss→https). Set explicitly only if the API lives on a
# different host than the WebSocket.
# VITE_API_URL=https://your-signaling.onrender.com

# ── TURN relay (Metered Free — no card) ───────────────────────────────────
# Needed so transfers still work when both peers are behind strict/symmetric
# NAT and direct P2P fails. STUN uses Google's free servers (hard-coded).
# Sign up at https://www.metered.ca → TURN Server → copy static credentials.
# The client already defaults VITE_TURN_DOMAIN to global.relay.metered.ca.
VITE_TURN_DOMAIN=global.relay.metered.ca
VITE_TURN_USERNAME=YOUR_METERED_USERNAME
VITE_TURN_CREDENTIAL=YOUR_METERED_CREDENTIAL

# ── Local testing only — DO NOT set in production ─────────────────────────
# VITE_FORCE_RELAY=true        # force the server WebSocket relay path (local test switch)
# VITE_RELAY_CAP_BYTES=        # override the 100 MB relay-session cap (local test only)
